@using clinic.BLL.ModelVM.Doctor

@model List<GetAllDoctorVM>

@{
    Layout = "~/Views/Shared/_AdminDashBoardLayout.cshtml";
    ViewData["Title"] = "AdminDashBoard";
}
<div class="content">
    <div class="row">
        <div class="col-sm-4 col-3">
            <h4 class="page-title">Doctors</h4>
        </div>
        <div class="col-sm-8 col-9 text-right m-b-20">
            <a asp-action="Create" asp-controller="AdminDashBoard" class="btn btn-primary btn-rounded float-right"><i class="fa fa-plus"></i> Add Doctor</a>
        </div>
    </div>
    <div class="row doctor-grid">
        @foreach(var result in Model)
        {
                <div class="col-md-4 col-sm-4  col-lg-3">
                            <div class="profile-widget">
                                <div class="doctor-img">
                                        <a class="avatar" href="profile.html"><img src="~/files/@result.DoctorImgUrl" alt="" style="width:80px; height:80px; border-radius:50%; object-fit:cover;"/></a>
                                </div>
                                <div class="dropdown profile-action">
                                    <a href="#" class="action-icon dropdown-toggle" data-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                                    <div class="dropdown-menu dropdown-menu-right">
                                        <a class="dropdown-item" href="edit-doctor.html"><i class="fa fa-pencil m-r-5"></i> Edit</a>
                                        <a class="dropdown-item" href="#" data-toggle="modal" data-target="#delete_doctor"><i class="fa fa-trash-o m-r-5"></i> Delete</a>
                                    </div>
                                </div>
                                <h4 class="doctor-name text-ellipsis"><a href="profile.html">@result.Name</a></h4>
                                <div class="doc-prof">@result.Specialization</div>
                                <div class="user-country">
                                     @result.YearsOfExperience years of experience
                                </div>
                         </div>
                    </div>
        }

                
      </div>
    </div>